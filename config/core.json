{
  "ghost.shell.display.dateFormat": "YYYY-MM-DD",
  "ghost.shell.display.timezone": "UTC",
  "ghost.shell.display.locale": "en-US",
  "ghost.shell.display.numberFormat": "en-US",
  "ghost.shell.behavior.autoSaveInterval": 30000,
  "ghost.shell.network.requestTimeout": 15000,
  "ghost.shell.network.retryCount": 3,
  "ghost.shell.security.sessionTimeout": 3600000,
  "ghost.shell.layout.sidebarPosition": "left",
  "ghost.shell.layout.defaultPanelSize": 300,
  "ghost.shell.migration.useContractCoreApi": true,
  "ghost.shell.migration.useAdapterComposition": true,
  "ghost.shell.migration.enableAsyncScompAdapter": false,
  "ghost.shell.migration.forceLegacyBridge": false,
  "ghost.shell.migration.enableCrossWindowDnd": true,
  "ghost.shell.migration.forceDisableCrossWindowDnd": false,
  "ghost.shell.placement.strategy": "dwindle",
  "ghost.shell.placement.dwindleDirection": "alternate"
}
