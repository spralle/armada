{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@ghost/formr-core": ["../../packages/formr-core/src/index.ts"],
      "@ghost/formr-from-schema": ["../../packages/formr-from-schema/src/index.ts"],
      "@ghost/formr-react": ["../../packages/formr-react/src/index.ts"],
      "@ghost/ui": ["../../packages/ui/src/index.ts"],
      "@ghost/plugin-contracts": ["../../packages/plugin-contracts/src/index.ts"],
      "@ghost/predicate": ["../../packages/predicate/src/index.ts"],
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
