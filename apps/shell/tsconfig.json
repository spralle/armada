{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "references": [
    {
      "path": "../../packages/plugin-contracts"
    },
    {
      "path": "../../packages/bridge"
    },
    {
      "path": "../../packages/intents"
    },
    {
      "path": "../../packages/router"
    },
    {
      "path": "../../packages/theme"
    },
    {
      "path": "../../packages/plugin-system"
    }
  ],
  "include": [
    "src"
  ]
}
