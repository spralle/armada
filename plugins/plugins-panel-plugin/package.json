{
  "name": "ghost.plugins-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Plugins Panel",
    "contributes": {
      "parts": [
        {
          "id": "ghost.shell.plugins",
          "title": "Plugins"
        }
      ]
    },
    "dependsOn": {
      "services": [
        {
          "id": "ghost.pluginRegistry.Service",
          "versionRange": "^1.0.0"
        },
        {
          "id": "ghost.pluginManagement.Service",
          "versionRange": "^1.0.0"
        },
        {
          "id": "ghost.syncStatus.Service",
          "versionRange": "^1.0.0"
        }
      ],
      "plugins": [
        {
          "pluginId": "ghost.ui",
          "versionRange": "^1.0.0"
        },
        {
          "pluginId": "ghost.shadcn.theme-bridge",
          "versionRange": "^1.0.0"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost/plugin-contracts": "file:../../packages/plugin-contracts",
    "@ghost/ui": "file:../../packages/ui",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.19"
  }
}
