{
  "name": "ghost.example-layer-modal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Example: Modal Layer",
    "contributes": {
      "layerSurfaces": [
        {
          "id": "example-modal",
          "component": "ModalSurface",
          "layer": "modal",
          "anchor": 0,
          "size": { "width": 480, "height": 320 },
          "inputBehavior": "opaque",
          "keyboardInteractivity": "exclusive",
          "focusGrab": {
            "backdrop": "rgba(0,0,0,0.5)",
            "dismissOnOutsideClick": true
          }
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost-shell/contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
