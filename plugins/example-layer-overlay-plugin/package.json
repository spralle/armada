{
  "name": "ghost.example-layer-overlay",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Example: Overlay Layer",
    "contributes": {
      "layerSurfaces": [
        {
          "id": "example-overlay-lock",
          "component": "OverlayLockSurface",
          "layer": "overlay",
          "anchor": 15,
          "inputBehavior": "opaque",
          "keyboardInteractivity": "exclusive",
          "sessionLock": true
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost/plugin-contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
