{
  "name": "ghost.domain.vessel-view",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Vessel View (RORO/ROPAX)",
    "contributes": {
      "parts": [
        {
          "id": "domain.vessel.view",
          "title": "Vessel View",
          "dock": {
            "container": "main"
          },
          "component": "VesselViewPart"
        }
      ],
      "actions": [
        {
          "id": "domain.vessel-view.open",
          "title": "Open Vessel View",
          "intent": "domain.entity.open",
          "when": {
            "entityType": {
              "$eq": "vessel"
            }
          }
        },
        {
          "id": "domain.vessel-view.inspect",
          "title": "Inspect Vessel Details",
          "intent": "domain.entity.inspect",
          "when": {
            "entityType": {
              "$eq": "vessel"
            }
          }
        }
      ],
      "selection": [
        {
          "id": "domain.vessel.selection",
          "receiverEntityType": "order",
          "interests": []
        }
      ]
    },
    "dependsOn": {
      "plugins": [
        {
          "pluginId": "ghost.shared.ui-capabilities",
          "versionRange": "^0.1.0"
        }
      ],
      "components": [
        {
          "id": "ghost.component.jsonform.control",
          "versionRange": "^0.1.0"
        },
        {
          "id": "ghost.component.entity-list.seed",
          "versionRange": "^0.1.0"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost-shell/contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
