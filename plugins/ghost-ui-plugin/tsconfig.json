{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "composite": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ghost-shell/ui": ["../../packages/ui/dist/index.d.ts"],
      "@ghost-shell/ui/*": ["../../packages/ui/dist/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/plugin-contracts"
    },
    {
      "path": "../../packages/ui"
    }
  ],
  "include": ["src"],
  "exclude": ["node_modules"]
}
