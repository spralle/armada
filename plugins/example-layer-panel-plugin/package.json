{
  "name": "ghost.example-layer-panel",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Example: Panel Layer",
    "contributes": {
      "layerSurfaces": [
        {
          "id": "example-panel",
          "component": "PanelSurface",
          "layer": "bottom",
          "anchor": 7,
          "size": {
            "width": 280
          },
          "exclusiveZone": 280,
          "inputBehavior": "opaque",
          "keyboardInteractivity": "on_demand"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost-shell/contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
