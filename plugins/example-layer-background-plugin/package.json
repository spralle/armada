{
  "name": "ghost.example-layer-background",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Example: Background Layer",
    "contributes": {
      "layerSurfaces": [
        {
          "id": "example-background",
          "component": "BackgroundSurface",
          "layer": "background",
          "anchor": 15,
          "exclusiveZone": -1,
          "inputBehavior": "passthrough",
          "keyboardInteractivity": "none",
          "opacity": 0.85
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost-shell/contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
