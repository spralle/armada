{
  "name": "ghost.view-picker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "View Picker",
    "contributes": {
      "actions": [
        {
          "id": "shell.view.open",
          "title": "View Picker: Open View",
          "intent": "shell.view.open"
        }
      ],
      "keybindings": [
        {
          "action": "shell.view.open",
          "keybinding": "ctrl+alt+o"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost/plugin-contracts": "file:../../packages/plugin-contracts"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "vite": "^5.4.19"
  }
}
