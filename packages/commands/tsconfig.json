{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "composite": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src"
  ],
  "exclude": ["src/**/__tests__", "src/**/*.test.ts", "src/**/*.spec.ts"],
  "references": [
    { "path": "../plugin-contracts" },
    { "path": "../intents" },
    { "path": "../persistence" },
    { "path": "../plugin-system" }
  ]
}
