{
  "name": "@ghost-shell/federation",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": null
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:dist": "tsup"
  },
  "dependencies": {
    "@ghost-shell/contracts": "workspace:*",
    "@ghost-shell/react": "workspace:*",
    "@ghost-shell/ui": "workspace:*"
  },
  "peerDependencies": {
    "@module-federation/enhanced": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
