{
  "name": "armada",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "tsc --pretty false -p tsconfig.json --noEmit",
    "typecheck": "tsc --pretty false -p tsconfig.json --noEmit",
    "test": "npm run build --silent && node --test packages/plugin-contracts/test/parse-plugin-contract.test.mjs",
    "build": "tsc -b --pretty false",
    "dev:shell": "bun --watch apps/shell/src/index.ts",
    "dev:backend": "bun --watch apps/backend/src/index.ts",
    "dev:plugin": "bun --watch apps/plugin-starter/src/index.ts",
    "dev:integration": "bun --watch apps/shell/src/index.ts",
    "scaffold:plugin": "node ./scripts/scaffold-plugin.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
